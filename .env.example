# База данных
DATABASE_URL=postgresql://cashflow:password@localhost:5432/cashflow?schema=public

# Telegram Bot
TELEGRAM_BOT_TOKEN=
# Секретный токен для проверки webhook-запросов от Telegram
TELEGRAM_BOT_SECRET=

# Telegram Admin IDs (через запятую)
ADMIN_TELEGRAM_IDS=616176317,5712505670
OWNER_TELEGRAM_IDS=
HOST_TELEGRAM_IDS=

# ЮКасса
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
# Опциональная HMAC-подпись от ЮКассы (если настроено в личном кабинете)
YUKASSA_WEBHOOK_SECRET=

# Next.js
NEXTAUTH_SECRET=
NEXT_PUBLIC_TG_APP_URL=https://your-domain.com
